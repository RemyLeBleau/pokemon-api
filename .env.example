# Copy to .env and set for deployment (optional; defaults work for local dev)
# PORT=3000
# NODE_ENV=development
# DB_PATH=./db/pokemon.sqlite

# Session secret for Express / Passport (change in production)
# SESSION_SECRET=super-secret-change-me

# Google OAuth — without both ID and secret, the server hides "Sign in with Google" and
# /api/auth/google-enabled returns enabled: false.
#
# 1. Google Cloud Console → APIs & Services → Credentials → Create OAuth client ID
#    (Web application). Add Authorized redirect URI exactly:
#      http://localhost:3000/auth/google/callback
#    (use your PORT if not 3000; or set GOOGLE_CALLBACK_URL to match.)
# 2. Copy Client ID and Client secret into a file named .env in this folder (copy from this file).
#
# GOOGLE_CLIENT_ID=xxxxx.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=xxxxx
# GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback

# PvP: seconds to pick a move before defaulting to move slot 1 (M1). Server uses MOVE_TURN_MS (ms).
# MOVE_TURN_MS=45000
